[
  { "id": 1, "name": "餓鬼（がき）", "minHp": 4, "maxHp": 8, "ac": 9, "minDmg": 2, "maxDmg": 3, "exp": 80, "image": "gaki.png", "flavor": "生前の強欲の報いにより、常に飢えと渇きに苦しむ亡者。腹は膨らみ、喉は針のように細い。" },
  { "id": 2, "name": "骸骨（がいこつ）", "minHp": 10, "maxHp": 18, "ac": 7, "minDmg": 4, "maxDmg": 7, "exp": 120, "image": "gaikotsu.png", "drops": [{ "itemId": 1, "rate": 0.08 }], "flavor": "戦場に打ち捨てられた骸が、無念の情によって動く。骨の軋む音は、死者の嘆きとも聞こえる。" },
  { "id": 3, "name": "鉄鼠（てっそ）", "minHp": 8, "maxHp": 15, "ac": 8, "minDmg": 3, "maxDmg": 5, "exp": 100, "image": "tessatsu.png", "drops": [{ "itemId": 3, "rate": 0.05 }], "flavor": "高僧の怨念が巨大な鼠と化した怪異。その歯は鉄をも噛み砕き、経典を食い荒らすという。" },
