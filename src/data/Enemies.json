  { "id": 7, "name": "青坊主（あおぼうず）", "minHp": 30, "maxHp": 50, "ac": 4, "minDmg": 10, "maxDmg": 20, "exp": 450, "image": "aobozu.png", "drops": [{ "itemId": 2, "rate": 0.20 }], "flavor": "巨大な青い法師の姿をした怪異。その一つ目に睨まれた者は、金縛りに遭い、動くことが叶わぬ。" },
