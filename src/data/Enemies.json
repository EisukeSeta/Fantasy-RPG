  { "id": 9, "name": "牛鬼（うしおに）", "minHp": 100, "maxHp": 180, "ac": 2, "minDmg": 25, "maxDmg": 50, "exp": 1500, "image": "ushioni.png", "statusEffect": "PARALYZED", "drops": [{ "itemId": 1, "rate": 0.30 }, { "itemId": 3, "rate": 0.20 }], "flavor": "牛の頭に蜘蛛の体を持つ、残忍極まりない巨怪。その咆哮は大地を震わせ、影を踏まれた者は動けなくなる。" },
  { "id": 10, "name": "鵺（ぬえ）", "minHp": 100, "maxHp": 160, "ac": 5, "minDmg": 20, "maxDmg": 40, "exp": 5000, "image": "nue.png", "isBoss": true, "drops": [{ "itemId": 100, "rate": 1.0 }], "flavor": "猿の顔、虎の手足、蛇の尾を持つ伝説の怪物。黒煙と共に現れ、都の夜に不吉な鳴き声を響かせる。" }
